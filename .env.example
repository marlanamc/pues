# Copy this file to .env and fill in your values.
# .env is gitignored — keys never leave your machine.

# ElevenLabs (required for /api/tts Spanish audio)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Supabase (optional — app works offline without these)
# Get from Project Settings → API after creating your project.
# See supabase/README.md for full setup.
NEXT_PUBLIC_SUPABASE_URL=

# The browser/public key. Two names for the SAME thing — set ONE:
#   • New projects: "publishable" key (sb_publishable_...) → use the line below
#   • Older projects: "anon"/public key (eyJ... JWT)        → use the ANON line
# Both are safe in the browser and respect Row Level Security.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. The "secret"/service_role key.
# Bypasses RLS. Optional, only needed for admin scripts.
SUPABASE_SERVICE_ROLE_KEY=
